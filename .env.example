# 포트 (기본값: 7373)
PORT=7373

# opencode exports 폴더 경로 (기본값: %USERPROFILE%\.local\share\opencode\exports)
# CHATLOG_EXPORTS_DIR=C:\Users\yourname\.local\share\opencode\exports

# 개발/테스트용: 현재 폴더의 jsonl 파일도 인덱싱
# CHATLOG_EXTRA_DIR=.

# 디바이스 라벨
CHATLOG_DEVICE=windows

# Bearer 인증 토큰 (설정 시 /mcp 엔드포인트에 인증 적용)
# CHATLOG_API_TOKEN=your-secret-token
